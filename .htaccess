Options -MultiViews

RewriteEngine On

# Redirect direct page file requests to their public slugs.
RewriteRule ^home\.php$ home [R=302,L,NC]
RewriteRule ^about\.php$ about-us [R=302,L,NC]
RewriteRule ^membership\.php$ membership [R=302,L,NC]
RewriteRule ^community\.php$ community [R=302,L,NC]
RewriteRule ^contact\.php$ contact-us [R=302,L,NC]

# Route all non-file, non-directory requests through the front controller.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
